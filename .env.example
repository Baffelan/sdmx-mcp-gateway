# SDMX MCP Gateway — environment variables
#
# Copy this file to .env and fill in values for local development, or set the
# same variables on your deployment host (e.g. Railway → Variables).
# The MCP server reads these via os.getenv at startup and at session time.

# ── Default endpoint ──────────────────────────────────────────────────────
# Key of the endpoint new sessions start on. Must match a key in
# SDMX_ENDPOINTS (see config.py). Falls back to "SPC" when unset.
# Valid: SPC, FBOS, SBS, ECB, UNICEF, IMF, OECD, ESTAT, ILO, ABS, BIS, STATSNZ
SDMX_ENDPOINT=SPC

# ── Custom endpoint override (optional) ───────────────────────────────────
# When SDMX_BASE_URL is set, it replaces the chosen endpoint's base URL
# entirely and the endpoint is treated as a generic "Custom SDMX Endpoint".
# Useful for pointing at a staging or on-prem SDMX server.
# SDMX_BASE_URL=https://your-sdmx.example/rest
# SDMX_AGENCY_ID=YOUR_AGENCY

# ── Provider subscription keys ────────────────────────────────────────────
# Required for endpoints whose config entry includes an "auth" block.
# When the key is unset, the client logs a WARNING on first use and requests
# will fail with 401. Store the value outside the repository (e.g. in
# ~/.sdmx-mcp-keys.env sourced before `uv run`, or as a Railway secret).

# Stats NZ (Aotearoa Data Explorer) — https://portal.apis.stats.govt.nz/
SDMX_STATSNZ_KEY=

# ── HTTP transport binding ────────────────────────────────────────────────
# Used when running with --transport streamable-http. Railway sets PORT
# automatically; HOST defaults to 0.0.0.0.
# HOST=0.0.0.0
# PORT=8000

# ── DNS rebinding protection ──────────────────────────────────────────────
# Comma-separated list of hostnames allowed in the Host header. Railway's
# RAILWAY_PUBLIC_DOMAIN and RAILWAY_PRIVATE_DOMAIN are also merged in
# automatically when set. Set this if running behind a custom domain.
# MCP_ALLOWED_HOSTS=example.com,api.example.com
